# Continue working past your Claude subscription limit by running Claude Code
# against Microsoft Foundry (Azure). Copy to .env.cloud and fill in your team's
# Foundry deployment. Usage bills to Azure — NOT your 5-hour subscription window.
#
#   scripts/claude-cloud       # launches Claude Code on the Azure backend
#   (or: npm run cloud)
#
# These are the exact variables Claude Code reads for the Foundry/Azure backend.
# Match them to how your team's Azure AI Foundry resource is set up.

CLAUDE_CODE_USE_FOUNDRY=1
ANTHROPIC_FOUNDRY_RESOURCE=your-foundry-resource-name
# Optional explicit endpoint (else derived from the resource name):
# ANTHROPIC_FOUNDRY_BASE_URL=https://your-resource.services.ai.azure.com

# --- Auth: use ONE of the following ---
# (a) API key:
ANTHROPIC_FOUNDRY_API_KEY=your-foundry-api-key
# (b) Azure AD service principal (leave the API key blank if you use this):
# AZURE_TENANT_ID=...
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...

# After you start using the cloud backend, tag those project folders in
# .env.local so Jarvis tracks them anonymously and keeps them out of your 5h
# window:  JARVIS_CLOUD_PROJECTS=my-team-project,another-azure-project
