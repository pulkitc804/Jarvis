# Copy this file to .env.local and fill in what you want to connect.
# Everything here is read SERVER-SIDE only and never sent to the browser.
# .env.local is gitignored — your secrets never leave your machine.

# ── Official Claude limits (optional) ───────────────────────────────────────
# Shows the TRUE Anthropic 5h / weekly % (same source as Claude Code's /usage).
# Without this, the Session panel still shows your real 5h window from local logs.
# Paste a Claude OAuth access token (sk-ant-oat01-...). It expires periodically.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
# Or, on macOS, read it from the Claude Code keychain item at runtime instead:
# CLAUDE_OAUTH_FROM_KEYCHAIN=1

# ── Meetings (Google / Outlook / Apple Calendar) ────────────────────────────
# Google Calendar → Settings → your calendar → "Secret address in iCal format".
# Comma-separate multiple calendars.
# CALENDAR_ICS_URLS=https://calendar.google.com/calendar/ical/.../basic.ics

# ── Email (Gmail over IMAP) ─────────────────────────────────────────────────
# Create a Google "App Password" (Account → Security → App passwords) — NOT your
# normal password. Requires 2-Step Verification enabled.
# GMAIL_IMAP_USER=you@gmail.com
# GMAIL_IMAP_APP_PASSWORD=abcd efgh ijkl mnop
# Non-Gmail IMAP instead:
# IMAP_HOST=imap.fastmail.com
# IMAP_PORT=993
# IMAP_USER=you@example.com
# IMAP_PASSWORD=app-password

# ── Telegram ────────────────────────────────────────────────────────────────
# Create a bot with @BotFather, paste the token. A bot sees messages sent to it
# and in groups/channels it's in (not your personal DMs with other people).
# TELEGRAM_BOT_TOKEN=123456789:AA...
